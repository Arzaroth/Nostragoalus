# --- Core ---
# Nuxt reads NUXT_-prefixed vars into runtimeConfig; drizzle-kit & better-auth CLI read the plain names.
NUXT_DATABASE_URL=postgres://nostragoalus:nostragoalus@localhost:5432/nostragoalus
DATABASE_URL=postgres://nostragoalus:nostragoalus@localhost:5432/nostragoalus

NUXT_BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_SECRET=replace-with-a-long-random-string

NUXT_PUBLIC_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Master key (KEK) that envelope-encrypts SSO provider secrets at rest.
# Generate with: openssl rand -base64 32   (must decode to 32 bytes)
# Google/OIDC/SAML sign-in is configured at runtime in /admin (no env vars needed).
NUXT_SSO_KEK=

# --- Match data provider ---
# fifa (default, keyless) | football-data | api-football
NUXT_MATCH_PROVIDER=fifa
# FIFA season id for the World Cup 2026 (from api.fifa.com); update if FIFA reassigns it.
NUXT_FIFA_SEASON_ID=285023
# Only needed for the football-data / api-football providers:
NUXT_FOOTBALL_DATA_TOKEN=
NUXT_API_FOOTBALL_KEY=
NUXT_WC_SEASON=2026

# Optional SMTP for 2FA email codes (TOTP authenticator works without it).
# e.g. smtp://user:pass@mail.example.com:587
NUXT_SMTP_URL=
NUXT_SMTP_FROM=

# --- Ops ---
NUXT_CRON_ENABLED=true
# Comma-separated list of admin emails (can trigger sync + import fixtures)
NUXT_ADMIN_EMAILS=
