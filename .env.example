# --- Core ---
# Nuxt reads NUXT_-prefixed vars into runtimeConfig; drizzle-kit & better-auth CLI read the plain names.
NUXT_DATABASE_URL=postgres://nostragoalus:nostragoalus@localhost:5432/nostragoalus
DATABASE_URL=postgres://nostragoalus:nostragoalus@localhost:5432/nostragoalus

NUXT_BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_SECRET=replace-with-a-long-random-string

NUXT_PUBLIC_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Master key (KEK) that envelope-encrypts SSO provider secrets at rest.
# Generate with: openssl rand -base64 32   (must decode to 32 bytes)
# Google/OIDC/SAML sign-in is configured at runtime in /admin (no env vars needed).
NUXT_SSO_KEK=

# Extra trusted origins (comma-separated) for an internal or self-hosted SSO IdP
# whose token endpoint is on a private network - the SSRF guard refuses such a host
# otherwise. Public IdPs (Google etc.) need nothing here.
NUXT_SSO_TRUSTED_ORIGINS=

# --- Match data provider ---
# Provider and season are per-competition (the `competition` table); FIFA seasons
# resolve from the DB or the live FIFA seasons API. Only optional API keys remain:
NUXT_FOOTBALL_DATA_TOKEN=
NUXT_API_FOOTBALL_KEY=

# Optional SMTP for 2FA email codes (TOTP authenticator works without it).
# e.g. smtp://user:pass@mail.example.com:587
# The compose stack ships maildev: codes land at http://localhost:1080 (SMTP smtp://maildev:1025).
NUXT_SMTP_URL=
NUXT_SMTP_FROM=

# --- Web push (PWA notifications) ---
# Required for push to work; without all three the push toggle stays hidden and
# nothing is sent. Generate a keypair with: npx web-push generate-vapid-keys
# Subject must be a mailto: or https: contact URL for the push service.
NUXT_PUBLIC_VAPID_PUBLIC_KEY=
NUXT_VAPID_PRIVATE_KEY=
NUXT_VAPID_SUBJECT=

# --- Voice chat (TURN relay) ---
# Self-hosted coturn (compose `voice` profile). Without these the app is STUN-only
# and calls behind symmetric NAT / strict firewalls fail. The secret mints
# ephemeral per-call credentials server-side (use-auth-secret) - keep it long and
# private; it must match coturn's --static-auth-secret. Host is the coturn
# hostname the browser reaches (e.g. turn.example.com); realm is coturn's realm.
NUXT_TURN_SECRET=
NUXT_TURN_HOST=
NUXT_TURN_REALM=nostragoalus
# Set to this host's PUBLIC IP when the coturn host is behind NAT (reached via a
# firewall port-forward) - otherwise coturn advertises its private LAN address as
# the relay and external browsers can't reach it. Leave blank only if coturn runs
# directly on a public IP.
NUXT_TURN_EXTERNAL_IP=
# TURN ports. Override to avoid clashing with another service on the host - e.g. a
# netbird relay already owns 3478 and the 49152-65535 range, so pick free ports
# like 3479 + a small relay window below 49152. The app and coturn read the same
# vars, so the ICE urls stay in step. Forward NUXT_TURN_PORT (udp+tcp) and the
# NUXT_TURN_MIN_PORT..MAX_PORT range (udp) in the firewall (+ the TLS port for turns:).
NUXT_TURN_PORT=3478
NUXT_TURN_TLS_PORT=5349
NUXT_TURN_MIN_PORT=49160
NUXT_TURN_MAX_PORT=49200

# --- Ops ---
NUXT_CRON_ENABLED=true
# Comma-separated list of admin emails (can trigger sync + import fixtures)
NUXT_ADMIN_EMAILS=

# --- Image storage ---
# Where avatars and chat images live (out of Postgres). 'fs' writes files under
# NUXT_STORAGE_FS_ROOT; 's3' talks to any S3-compatible endpoint. The docker deploy
# runs rustfs and sets driver=s3 (see compose.yaml). Local dev defaults to fs.
NUXT_STORAGE_DRIVER=fs
# fs driver: absolute path inside the app (container default /data/storage). Unset
# in dev falls back to ./.data/storage.
NUXT_STORAGE_FS_ROOT=
# s3 driver: required when NUXT_STORAGE_DRIVER=s3. Path-style endpoint, e.g.
# http://rustfs:9000 in-network.
NUXT_STORAGE_S3_ENDPOINT=
NUXT_STORAGE_S3_REGION=us-east-1
NUXT_STORAGE_S3_BUCKET=nostragoalus
NUXT_STORAGE_S3_ACCESS_KEY_ID=
NUXT_STORAGE_S3_SECRET_ACCESS_KEY=
