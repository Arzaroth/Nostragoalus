#!/usr/bin/env -S node
//MISE description="Create or promote an admin (prompts for password; needs the stack up)"
//USAGE arg "<email>" help="Email of the admin to create or promote"
//USAGE arg "[name]" help="Display name (defaults to the email local-part)"

// Reuses better-auth's own signup (scrypt hashing, HIBP breach check, account
// row) against the running app, then sets role=admin in the DB so it doesn't
// rely on NUXT_ADMIN_EMAILS. The password is prompted for (hidden), never an
// argument, so it stays out of shell history and the process list. Idempotent.
import { createInterface } from 'node:readline'
import { stdin, stdout } from 'node:process'
import { execFileSync } from 'node:child_process'

const email = process.env.usage_email
const name = (process.env.usage_name || '').trim() || (email ? email.split('@')[0] : '')
const APP = process.env.APP_URL ?? 'http://localhost:3000'

if (!email) {
  console.error('usage: mise run create-admin <email> [name]')
  process.exit(1)
}

// Piped (automation/test): read the whole stream once and pull lines from it -
// a per-question readline races with buffered pipe input. Interactive TTY: a
// muted readline so the password isn't echoed.
const tty = stdin.isTTY === true
let pipedLines = null
async function askHidden(question) {
  if (!tty) {
    if (pipedLines === null) {
      const chunks = []
      for await (const c of stdin) chunks.push(c)
      pipedLines = Buffer.concat(chunks).toString('utf8').split(/\r?\n/)
    }
    return pipedLines.shift() ?? ''
  }
  return new Promise((resolve) => {
    const rl = createInterface({ input: stdin, output: stdout, terminal: true })
    let muted = false
    rl._writeToOutput = (str) => {
      if (!muted) stdout.write(str)
    }
    rl.question(question, (value) => {
      rl.close()
      stdout.write('\n')
      resolve(value)
    })
    muted = true
  })
}

const password = await askHidden(`Password for ${email}: `)
const confirm = await askHidden('Confirm password: ')
if (password.length < 8) {
  console.error('password must be at least 8 characters')
  process.exit(1)
}
if (password !== confirm) {
  console.error('passwords do not match')
  process.exit(1)
}

// 1. Sign up through better-auth (hashing + HIBP happen here). A duplicate is fine.
const res = await fetch(`${APP}/api/auth/sign-up/email`, {
  method: 'POST',
  headers: { 'content-type': 'application/json', Origin: APP },
  body: JSON.stringify({ name, email, password }),
})
if (res.ok) {
  console.log(`signed up ${email}`)
} else {
  const msg = await res.text()
  const exists = /exist|already/i.test(msg)
  if (!exists) {
    console.error(`sign-up failed (${res.status}): ${msg.slice(0, 200)}`)
    console.error('(a breached password is rejected by HIBP - choose a stronger one)')
    process.exit(1)
  }
  console.log(`${email} already exists - promoting`)
}

// 2. Promote to admin in the DB. Admin accounts start hidden from the
// leaderboard (they run the game, they don't compete); an admin can unhide
// any account from /admin later.
// psql via docker (like db-backup) so this needs no node_modules on a prod host.
// :'email' is psql's quoted-literal interpolation (no hand-built SQL); RETURNING
// + -tA prints one id per updated row, so empty output means nothing matched.
const out = execFileSync(
  'docker',
  [
    'compose', 'exec', '-T', 'db',
    'psql', '-U', 'nostragoalus', '-d', 'nostragoalus', '-tA',
    '-v', 'ON_ERROR_STOP=1',
    '-v', `email=${email}`,
  ],
  {
    input: `UPDATE "user" SET role = 'admin', hidden_from_leaderboard = true WHERE lower(email) = lower(:'email') RETURNING id;`,
    encoding: 'utf8',
  },
)
if (!out.trim()) {
  console.error(`no user row for ${email} - sign-up did not create one; nothing promoted`)
  process.exit(1)
}
console.log(`${email} is now an admin`)
