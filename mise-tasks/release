#!/usr/bin/env bash
#MISE description="Cut a release: changelog section, version bump, full gate, commit+tag+push"
#USAGE arg "<version>" help="Semver to release, e.g. 0.13.0"
#USAGE flag "--dry-run" help="Preview the release without writing, committing or pushing"

# Move [Unreleased] into a dated version section, bump package.json, run the gate
# (typecheck + coverage + component tests), commit, tag, push. Plain shell; the
# only structured-text edits delegate out - jq for package.json, the `changelog`
# mise task for the [Unreleased] move (both far less brittle than sed/awk here).
set -euo pipefail

version="${usage_version:-}"
dry_run="${usage_dry_run:-false}"

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "usage: mise run release <x.y.z> [--dry-run]" >&2
  exit 1
fi
if [[ -n "$(git status --porcelain)" ]]; then
  echo "working tree is not clean - commit or stash first" >&2
  exit 1
fi
if git tag -l | grep -qx "v${version}"; then
  echo "tag v${version} already exists" >&2
  exit 1
fi

pending="$(mise run changelog read)"
if [[ -z "$pending" ]]; then
  echo "CHANGELOG.md has no [Unreleased] content - nothing to release" >&2
  exit 1
fi

date="$(date +%F)"
printf 'releasing v%s (%s) with:\n\n%s\n\n' "$version" "$date" "$pending"
if [[ "$dry_run" == "true" ]]; then
  echo "dry run - nothing written"
  exit 0
fi

# Move [Unreleased] -> dated section (changelog task) and bump the version (jq).
mise run changelog promote "$version" "$date"
tmp="$(mktemp)"
jq --indent 2 --arg v "$version" '.version = $v' package.json > "$tmp"
mv "$tmp" package.json

echo "running the gate (typecheck + coverage + component tests + prod build)..."
export CI=true
pnpm typecheck
pnpm test:coverage
pnpm test:components
# Build last: catches SSR/rollup link errors (e.g. unresolved imports) that
# typecheck and the unit/component suites miss, so a release tag always builds.
pnpm build

git add CHANGELOG.md package.json
git commit -m "chore(release): ${version}"
git tag -a "v${version}" -m "Nostragoalus ${version}"
git push origin master --follow-tags
echo
echo "released v${version}"
