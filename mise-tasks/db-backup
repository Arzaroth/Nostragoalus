#!/usr/bin/env -S node
//MISE description="Back up the dockerized Postgres + image object storage to backups/"
//USAGE arg "[outdir]" help="Destination directory (default: ./backups)"
//USAGE flag "--keep <n>" help="Keep only the newest N backups (env BACKUP_KEEP; 0 = unlimited)"
//USAGE flag "--max-age-days <d>" help="Delete backups older than D days (env BACKUP_MAX_AGE_DAYS; 0 = unlimited)"
//USAGE flag "--no-media" help="Skip the object-storage (image) backup, e.g. an fs-driver deploy (env BACKUP_SKIP_MEDIA)"

// Equivalent raw commands:
//   docker compose exec -T db pg_dump -U nostragoalus -Fc nostragoalus > backups/nostragoalus-<stamp>.dump
//   docker compose --profile tools run --rm -v <outdir>:/backups mc mirror --overwrite --remove ng/<bucket> /backups/media-<stamp>
// The DB dump (custom format, -Fc) is compressed and restorable table-by-table.
// The media mirror copies the image bucket object-for-object (consistent, unlike
// tarring a live store), AFTER the dump - so the image set is a superset of the
// DB's references and a restore never finds a row pointing at a missing image.
import { execFileSync } from 'node:child_process'
import { mkdirSync, statSync, readdirSync, unlinkSync, rmSync, openSync, closeSync, readFileSync } from 'node:fs'
import { resolve } from 'node:path'

// Resolve the S3 bucket the way docker compose does (from .env), since mise does
// not autoload .env into this process - otherwise a customized bucket that is not
// exported to the shell would silently fall back to the default and mistarget.
function s3Bucket() {
  if (process.env.NUXT_STORAGE_S3_BUCKET) return process.env.NUXT_STORAGE_S3_BUCKET
  try {
    const m = readFileSync('.env', 'utf8').match(/^\s*NUXT_STORAGE_S3_BUCKET\s*=\s*(.+?)\s*$/m)
    if (m) return m[1].replace(/^["']|["']$/g, '')
  } catch {
    // no .env (or unreadable) - fall through to the default
  }
  return 'nostragoalus'
}

const outdir = process.env.usage_outdir || 'backups'
mkdirSync(outdir, { recursive: true })

const stamp = new Date().toISOString().replace(/[:T]/g, '-').slice(0, 19)
const file = `${outdir}/nostragoalus-${stamp}.dump`

// No shell: pg_dump's stdout is redirected to the dump file via an fd, so the path
// (which can come from the [outdir] arg) is never parsed by a shell.
const dumpFd = openSync(file, 'w')
try {
  execFileSync('docker', ['compose', 'exec', '-T', 'db', 'pg_dump', '-U', 'nostragoalus', '-Fc', 'nostragoalus'], {
    stdio: ['ignore', dumpFd, 'inherit'],
  })
} finally {
  closeSync(dumpFd)
}

const size = statSync(file).size
if (size < 1024) {
  console.error(`${file} is suspiciously small (${size} bytes) - is the db container up?`)
  process.exit(1)
}
console.log(`wrote ${file} (${(size / 1024 / 1024).toFixed(1)} MiB)`)

// Image object storage. Skipped for an fs-driver deploy (--no-media / env var).
// execFileSync (no shell) so the bucket/paths can't inject anything.
const skipMedia = Boolean(process.env.usage_no_media || process.env.BACKUP_SKIP_MEDIA)
if (!skipMedia) {
  const bucket = s3Bucket()
  console.log(`mirroring bucket ${bucket} -> ${outdir}/media-${stamp}`)
  execFileSync(
    'docker',
    [
      'compose', '--profile', 'tools', 'run', '--rm', '-v', `${resolve(outdir)}:/backups`, 'mc',
      'mirror', '--overwrite', '--remove', `ng/${bucket}`, `/backups/media-${stamp}`,
    ],
    { stdio: ['ignore', 'inherit', 'inherit'] },
  )
}

// Retention: prune old DB dumps and their paired media dirs by count and/or age.
// Both default to unlimited, so without flags/env nothing is deleted. CLI flags
// win over env vars.
const keep = Number(process.env.usage_keep || process.env.BACKUP_KEEP || 0)
const maxAgeDays = Number(process.env.usage_max_age_days || process.env.BACKUP_MAX_AGE_DAYS || 0)
if (keep > 0 || maxAgeDays > 0) {
  const dumps = readdirSync(outdir)
    .filter((f) => /^nostragoalus-.*\.dump$/.test(f))
    .map((f) => ({
      stamp: f.slice('nostragoalus-'.length, -'.dump'.length),
      path: `${outdir}/${f}`,
      mtime: statSync(`${outdir}/${f}`).mtimeMs,
    }))
    .sort((a, b) => b.mtime - a.mtime) // newest first
  const doomed = new Map()
  if (keep > 0) dumps.slice(keep).forEach((d) => doomed.set(d.path, d.stamp))
  if (maxAgeDays > 0) {
    const cutoff = Date.now() - maxAgeDays * 86_400_000
    dumps.forEach((d) => d.mtime < cutoff && doomed.set(d.path, d.stamp))
  }
  doomed.delete(file) // never prune the dump we just wrote
  for (const [path, st] of doomed) {
    unlinkSync(path)
    console.log(`pruned ${path}`)
    rmSync(`${outdir}/media-${st}`, { recursive: true, force: true }) // its paired media, if any
  }
}

console.log(`restore with: mise run db-restore ${file}`)
