#!/usr/bin/env -S node
//MISE description="Restore a Postgres dump and its paired image backup (DESTRUCTIVE)"
//USAGE arg "<file>" help="Backup file produced by db-backup (.dump)"
//USAGE flag "--no-media" help="Skip restoring the object-storage (image) backup"

// Equivalent raw commands:
//   docker compose exec -T db pg_restore -U nostragoalus -d nostragoalus --clean --if-exists < backups/<file>
//   docker compose --profile tools run --rm -v <dir>:/backups mc mirror --overwrite --remove /backups/media-<stamp> ng/<bucket>
// --clean --if-exists drops and recreates DB objects; the media mirror (--remove)
// makes the bucket match the backup exactly. Stop the app first if it is mid-write.
import { execFileSync } from 'node:child_process'
import { existsSync, statSync, openSync, closeSync, readFileSync } from 'node:fs'
import { basename, dirname, resolve } from 'node:path'
import { createInterface } from 'node:readline/promises'

// Resolve the S3 bucket the way docker compose does (from .env), since mise does
// not autoload .env into this process - otherwise a customized bucket that is not
// exported to the shell would silently fall back to the default and mistarget.
function s3Bucket() {
  if (process.env.NUXT_STORAGE_S3_BUCKET) return process.env.NUXT_STORAGE_S3_BUCKET
  try {
    const m = readFileSync('.env', 'utf8').match(/^\s*NUXT_STORAGE_S3_BUCKET\s*=\s*(.+?)\s*$/m)
    if (m) return m[1].replace(/^["']|["']$/g, '')
  } catch {
    // no .env (or unreadable) - fall through to the default
  }
  return 'nostragoalus'
}

const file = process.env.usage_file
if (!file || !existsSync(file)) {
  console.error('usage: mise run db-restore <backup.dump>')
  process.exit(1)
}

// The paired image backup sits next to the dump as media-<stamp>/.
const skipMedia = Boolean(process.env.usage_no_media)
const stamp = basename(file).match(/^nostragoalus-(.+)\.dump$/)?.[1] ?? null
const mediaDir = stamp ? `${dirname(file)}/media-${stamp}` : null
const hasMedia = mediaDir != null && existsSync(mediaDir) && statSync(mediaDir).isDirectory()

// Preflight before the destructive DB restore: refuse to drop+recreate the DB if
// its paired image backup is expected but absent (--no-media not set), since that
// would leave a restored DB whose rows reference images that are not there.
if (!skipMedia && !hasMedia) {
  console.error(`no paired image backup next to ${file} (expected media-${stamp ?? '<stamp>'}/). Pass --no-media to restore the database alone.`)
  process.exit(1)
}

if (process.stdin.isTTY) {
  const rl = createInterface({ input: process.stdin, output: process.stdout })
  const answer = await rl.question(
    `This OVERWRITES the current database${hasMedia ? ' and image storage' : ''} with ${file}${hasMedia ? ` and ${mediaDir}` : ''}. Type "yes" to continue: `,
  )
  rl.close()
  if (answer.trim() !== 'yes') {
    console.error('aborted')
    process.exit(1)
  }
}

// No shell: the dump is fed to pg_restore on stdin via an fd, so the file path
// (a user-supplied arg) is never parsed by a shell.
const restoreFd = openSync(file, 'r')
try {
  execFileSync('docker', ['compose', 'exec', '-T', 'db', 'pg_restore', '-U', 'nostragoalus', '-d', 'nostragoalus', '--clean', '--if-exists'], {
    stdio: [restoreFd, 'inherit', 'inherit'],
  })
} finally {
  closeSync(restoreFd)
}
console.log(`restored ${file}`)

if (!skipMedia && hasMedia) {
  const bucket = s3Bucket()
  console.log(`mirroring ${mediaDir} -> bucket ${bucket}`)
  execFileSync(
    'docker',
    [
      'compose', '--profile', 'tools', 'run', '--rm', '-v', `${resolve(dirname(file))}:/backups`, 'mc',
      'mirror', '--overwrite', '--remove', `/backups/media-${stamp}`, `ng/${bucket}`,
    ],
    { stdio: ['ignore', 'inherit', 'inherit'] },
  )
  console.log(`restored images from ${mediaDir}`)
}
