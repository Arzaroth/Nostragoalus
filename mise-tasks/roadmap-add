#!/usr/bin/env -S node
//MISE description="Add an item to the public roadmap (direct DB insert)"
//USAGE arg "<title>" help="Item title (3-120 chars)"
//USAGE arg "[description]" help="Optional description"
//USAGE flag "-s --status <status>" help="PLANNED (default), IN_PROGRESS or SHIPPED"

// Talks to the dockerized Postgres via `docker compose exec db psql` (same as
// db-backup), so it needs no node_modules - works on a prod host with only the
// built app deployed. Values are passed as psql variables and interpolated with
// :'var' (psql quotes/escapes them), so there's no hand-rolled SQL string
// building; execFileSync runs without a shell, so no shell quoting either.
import { execFileSync } from 'node:child_process'

const title = (process.env.usage_title || '').trim()
const description = (process.env.usage_description || '').trim()
const status = (process.env.usage_status || 'PLANNED').toUpperCase()

const STATUSES = ['PLANNED', 'IN_PROGRESS', 'SHIPPED']
if (title.length < 3 || title.length > 120) {
  console.error('usage: mise run roadmap-add <title> [description] [-s status] - title must be 3-120 chars')
  process.exit(1)
}
if (!STATUSES.includes(status)) {
  console.error(`status must be one of: ${STATUSES.join(', ')}`)
  process.exit(1)
}

// :'var' = psql's quoted-literal interpolation; NULLIF turns an empty
// description into NULL. position is per-status (append at the end).
const sql = `INSERT INTO roadmap_item (id, title, description, status, position)
SELECT gen_random_uuid()::text, :'title', NULLIF(:'descr', ''), :'st'::roadmap_status, COALESCE(MAX(position), -1) + 1
FROM roadmap_item WHERE status = :'st'::roadmap_status
RETURNING id;`

const out = execFileSync(
  'docker',
  [
    'compose', 'exec', '-T', 'db',
    'psql', '-U', 'nostragoalus', '-d', 'nostragoalus', '-tA',
    '-v', 'ON_ERROR_STOP=1',
    '-v', `title=${title}`,
    '-v', `descr=${description}`,
    '-v', `st=${status}`,
  ],
  { input: sql, encoding: 'utf8' },
)
console.log(`added roadmap item ${out.trim().split('\n')[0]} [${status}] ${title}`)
