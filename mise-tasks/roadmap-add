#!/usr/bin/env -S node
//MISE description="Add an item to the public roadmap (direct DB insert)"
//USAGE arg "<title>" help="Item title (3-120 chars)"
//USAGE arg "[description]" help="Optional description"
//USAGE flag "-s --status <status>" help="PLANNED (default), IN_PROGRESS or SHIPPED"

// Talks to the dockerized Postgres via `docker compose exec db psql` (same as
// db-backup), so it needs no node_modules - works on a prod host with only the
// built app deployed.
import { execSync } from 'node:child_process'

const title = (process.env.usage_title || '').trim()
const description = (process.env.usage_description || '').trim() || null
const status = (process.env.usage_status || 'PLANNED').toUpperCase()

const STATUSES = ['PLANNED', 'IN_PROGRESS', 'SHIPPED']
if (title.length < 3 || title.length > 120) {
  console.error('usage: mise run roadmap-add <title> [description] [-s status] - title must be 3-120 chars')
  process.exit(1)
}
if (!STATUSES.includes(status)) {
  console.error(`status must be one of: ${STATUSES.join(', ')}`)
  process.exit(1)
}

const q = (s) => (s === null ? 'NULL' : `'${String(s).replace(/'/g, "''")}'`)
// Append at the end of the status column (position is per-status).
const sql = `INSERT INTO roadmap_item (id, title, description, status, position)
SELECT gen_random_uuid()::text, ${q(title)}, ${q(description)}, ${q(status)}::roadmap_status, COALESCE(MAX(position), -1) + 1
FROM roadmap_item WHERE status = ${q(status)}::roadmap_status
RETURNING id;`

const out = execSync('docker compose exec -T db psql -U nostragoalus -d nostragoalus -tA -v ON_ERROR_STOP=1', {
  input: sql,
  encoding: 'utf8',
  shell: '/bin/sh',
})
const id = out.trim().split('\n')[0]
console.log(`added roadmap item ${id} [${status}] ${title}`)
