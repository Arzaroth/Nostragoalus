#!/usr/bin/env -S node
//MISE description="Seed the public roadmap with a curated starter set (idempotent)"
//USAGE flag "--force" help="Insert even if the roadmap table is not empty (appends)"
//USAGE flag "--reset" help="Delete all existing roadmap items first, then seed (clean state)"

// One-time bootstrap so a fresh deploy's /roadmap isn't empty. After this the
// roadmap is managed from the admin panel - editing this seed only affects a
// fresh (still-empty) table, not a roadmap that already has items.
//
// Talks to the dockerized Postgres via `docker compose exec db psql` (same as
// db-backup), so it needs no node_modules - works on a prod host with only the
// built app deployed.
import { execSync } from 'node:child_process'

const force = process.env.usage_force === 'true'
const reset = process.env.usage_reset === 'true'

