#!/usr/bin/env -S node
//MISE description="Seed the public roadmap with a curated starter set (idempotent)"
//USAGE flag "--force" help="Insert even if the roadmap table is not empty (appends)"
//USAGE flag "--reset" help="Delete all existing roadmap items first, then seed (clean state)"

// One-time bootstrap so a fresh deploy's /roadmap isn't empty. After this the
// roadmap is managed from the admin panel - editing this seed only affects a
// fresh (still-empty) table, not a roadmap that already has items.
//
// Talks to the dockerized Postgres via `docker compose exec db psql` (same as
// db-backup), so it needs no node_modules - works on a prod host with only the
// built app deployed.
import { execSync } from 'node:child_process'

const force = process.env.usage_force === 'true'
const reset = process.env.usage_reset === 'true'

// Curated, public-facing subset of ROADMAP.md (internal notes stay internal).
// Order within a status = display order (position).
const ITEMS = [
  { status: 'SHIPPED', title: 'Public roadmap', description: 'This page - admin-curated, so you can see what we are building.' },
  { status: 'SHIPPED', title: 'Live play-by-play', description: 'Full minute-by-minute match timeline (goals, cards, subs, shots, penalties, VAR) in its own tab on the match page, straight from the live feed.' },
  { status: 'SHIPPED', title: 'Next-match reminder on the home page', description: 'Signed in, the home page nudges you toward the next kickoff - teams, countdown and a one-click jump to your picks. Scroll past it and it stays gone for that match.' },
  { status: 'SHIPPED', title: 'Auto-refresh on new version', description: 'A "new version available" prompt when the app updates, so you are never on a stale build.' },
  { status: 'SHIPPED', title: 'League invite links', description: 'Share a link to join your league, with optional expiry and a max number of uses.' },
  { status: 'SHIPPED', title: 'Email verification for sign-ups', description: 'Optionally confirm your email address when creating an account - turned on by the admins once mail is set up.' },
  { status: 'SHIPPED', title: 'Cron tasks admin view', description: 'An admin view of the scheduled background jobs - their schedule, next and last run, run count and last result - with one-click run-now and the last output or error on tap.' },
  { status: 'SHIPPED', title: 'Localized play-by-play', description: 'The minute-by-minute match timeline now reads in your own language - goals, cards, subs, fouls and period markers - with VAR decisions and a referee-whistle icon.' },
  { status: 'SHIPPED', title: 'Play-by-play for UEFA matches', description: 'The minute-by-minute timeline - goals, cards, subs, shots, fouls, period markers and VAR decisions - now covers UEFA competition matches (the Euro) too, not just the World Cup.' },
  { status: 'IN_PROGRESS', title: 'Main page rework', description: 'A rolling refresh of the home page to get you to the matches and your picks faster. First up: the banner now slides up into a slim header bar - tap the cue beneath it, or just scroll - instead of a full-screen splash. More to follow.' },
  { status: 'SHIPPED', title: 'Admin panel redesign', description: 'The admin panel swaps one long scroll for a left-hand menu - sign-ups, SSO, users, leagues, roadmap and scheduled tasks each get their own page with room to breathe.' },
  { status: 'SHIPPED', title: 'Second chance for champion & Golden Boot picks', description: 'Once the group stage is nearly over, get one last chance to switch your tournament-winner and top-scorer picks - for half the points. Your original call stays on show beside the new one.' },
  { status: 'SHIPPED', title: 'Tunable scoring & a rarity bonus for the result', description: 'Admins can adjust the points, bonuses and rarity tiers (per competition if needed), and a new bonus rewards calling a rare but correct result - backing the underdog when most of the field went the other way.' },
  { status: 'SHIPPED', title: 'League standings per match', description: 'On a match that has kicked off, a League tab ranks your league mates by the points their pick earns on that match - updating live with the score and settling at full-time.' },
  { status: 'SHIPPED', title: 'Champion points repaired after the ranking outage', description: 'Champion picks made while the FIFA ranking feed was down were stuck on the flat bonus with no rank shown; their proper rank-tier points have been restored.' },
  { status: 'SHIPPED', title: 'Match watch links', description: 'Admin-curated Live, Replay and Highlights links on the match page - playing inline when the source allows it, otherwise opening in a new tab.' },
  { status: 'SHIPPED', title: 'Notification center', description: 'A bell in the header gathering what matters to you - reminders for matches locking soon you have not picked, your match results, league activity, and how your champion and Golden Boot picks finished - with an unread count and live updates as things happen.' },
  { status: 'SHIPPED', title: 'Group standings on the fixtures page', description: 'Flip the fixtures page to a live-aware table for every group at once (played, won, drawn, lost, goal difference, points), shareable via a link.' },
  { status: 'IN_PROGRESS', title: 'Match reactions', description: 'React to a match with a quick emoji once it kicks off - counts climb live for everyone watching, and you see how your league reacted next to the global tally when you have a league selected.' },
  { status: 'PLANNED', title: 'New-since-last-visit changelog', description: 'A badge on the changelog highlighting what shipped since you last looked.' },
  { status: 'PLANNED', title: 'Calendar feed', description: 'Subscribe to fixtures and pick-lockout deadlines from your own calendar app (iCal).' },
  { status: 'SHIPPED', title: 'Web push notifications', description: 'Opt in to push notifications on your phone or desktop: pick reminders, kickoff and live goal alerts on matches you predicted, your results, and league activity - each switchable on or off in your preferences.' },
  { status: 'PLANNED', title: 'Tournament Wrapped', description: 'An end-of-competition recap - best and worst pick, joker efficiency, your percentile - with a shareable card.' },
  { status: 'PLANNED', title: 'Personal & what-if stats', description: 'See where a joker would have helped, how you compare to the crowd, and your prediction biases.' },
]

const q = (s) => (s === null ? 'NULL' : `'${String(s).replace(/'/g, "''")}'`)
const next = {}
const values = ITEMS.map((it) => {
  const pos = next[it.status] ?? 0
  next[it.status] = pos + 1
  return `(gen_random_uuid()::text, ${q(it.title)}, ${q(it.description)}, ${q(it.status)}::roadmap_status, ${pos})`
}).join(',\n  ')

// The WHERE on the SELECT (from a VALUES list) makes it a no-op when the table
// already has items, unless --force/--reset drops the guard. --reset first
// wipes the table so the seed becomes the whole roadmap again (clean state).
const guard = force || reset ? '' : '\nWHERE (SELECT count(*) FROM roadmap_item) = 0'
const wipe = reset ? 'DELETE FROM roadmap_item;\n' : ''
const sql = `${wipe}INSERT INTO roadmap_item (id, title, description, status, position)
SELECT * FROM (VALUES
  ${values}
) AS v(id, title, description, status, position)${guard};`

const out = execSync('docker compose exec -T db psql -U nostragoalus -d nostragoalus -v ON_ERROR_STOP=1', {
  input: sql,
  encoding: 'utf8',
  shell: '/bin/sh',
})
const inserted = Number(/INSERT \d+ (\d+)/.exec(out)?.[1] ?? 0)
console.log(inserted > 0 ? `seeded ${inserted} roadmap item(s)` : 'roadmap already has items - skipped (pass --reset to wipe and reseed, or --force to append)')
