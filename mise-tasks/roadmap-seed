const q = (s) => (s === null ? 'NULL' : `'${String(s).replace(/'/g, "''")}'`)
const next = {}
const values = ITEMS.map((it) => {
  const pos = next[it.status] ?? 0
  next[it.status] = pos + 1
  return `(gen_random_uuid()::text, ${q(it.title)}, ${q(it.description)}, ${q(it.status)}::roadmap_status, ${pos})`
}).join(',\n  ')

// The WHERE on the SELECT (from a VALUES list) makes it a no-op when the table
// already has items, unless --force/--reset drops the guard. --reset first
// wipes the table so the seed becomes the whole roadmap again (clean state).
const guard = force || reset ? '' : '\nWHERE (SELECT count(*) FROM roadmap_item) = 0'
const wipe = reset ? 'DELETE FROM roadmap_item;\n' : ''
const sql = `${wipe}INSERT INTO roadmap_item (id, title, description, status, position)
SELECT * FROM (VALUES
  ${values}
) AS v(id, title, description, status, position)${guard};`

const out = execSync('docker compose exec -T db psql -U nostragoalus -d nostragoalus -v ON_ERROR_STOP=1', {
  input: sql,
  encoding: 'utf8',
  shell: '/bin/sh',
})
const inserted = Number(/INSERT \d+ (\d+)/.exec(out)?.[1] ?? 0)
console.log(inserted > 0 ? `seeded ${inserted} roadmap item(s)` : 'roadmap already has items - skipped (pass --reset to wipe and reseed, or --force to append)')
