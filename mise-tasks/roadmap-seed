#!/usr/bin/env -S node
//MISE description="Seed the public roadmap with a curated starter set (idempotent)"
//USAGE flag "--force" help="Insert even if the roadmap table is not empty"

// One-time bootstrap so a fresh deploy's /roadmap isn't empty. After this the
// roadmap is managed from the admin panel - editing this seed only affects a
// fresh (still-empty) table, not a roadmap that already has items.
//
// Talks to the dockerized Postgres via `docker compose exec db psql` (same as
// db-backup), so it needs no node_modules - works on a prod host with only the
// built app deployed.
import { execSync } from 'node:child_process'

const force = process.env.usage_force === 'true'

// Curated, public-facing subset of ROADMAP.md (internal notes stay internal).
// Order within a status = display order (position).
const ITEMS = [
  { status: 'SHIPPED', title: 'Public roadmap', description: 'This page - admin-curated, so you can see what we are building.' },
  { status: 'SHIPPED', title: 'Live play-by-play', description: 'Full minute-by-minute match timeline (goals, cards, subs, shots, penalties, VAR) in its own tab on the match page, straight from the live feed.' },
  { status: 'SHIPPED', title: 'Next-match reminder on the home page', description: 'Signed in, the home page nudges you toward the next kickoff - teams, countdown and a one-click jump to your picks. Scroll past it and it stays gone for that match.' },
  { status: 'SHIPPED', title: 'Auto-refresh on new version', description: 'A "new version available" prompt when the app updates, so you are never on a stale build.' },
  { status: 'IN_PROGRESS', title: 'League invite links', description: 'Share a link to join your league, with optional expiry and a max number of uses.' },
  { status: 'PLANNED', title: 'New-since-last-visit changelog', description: 'A badge on the changelog highlighting what shipped since you last looked.' },
  { status: 'PLANNED', title: 'Calendar feed', description: 'Subscribe to fixtures and pick-lockout deadlines from your own calendar app (iCal).' },
  { status: 'PLANNED', title: 'Pick reminders & web push', description: 'Installable app with notifications: lockout reminders for missing picks and goal alerts on your matches.' },
  { status: 'PLANNED', title: 'Tournament Wrapped', description: 'An end-of-competition recap - best and worst pick, joker efficiency, your percentile - with a shareable card.' },
  { status: 'PLANNED', title: 'Personal & what-if stats', description: 'See where a joker would have helped, how you compare to the crowd, and your prediction biases.' },
]

const q = (s) => (s === null ? 'NULL' : `'${String(s).replace(/'/g, "''")}'`)
const next = {}
const values = ITEMS.map((it) => {
  const pos = next[it.status] ?? 0
  next[it.status] = pos + 1
  return `(gen_random_uuid()::text, ${q(it.title)}, ${q(it.description)}, ${q(it.status)}::roadmap_status, ${pos})`
}).join(',\n  ')

// The WHERE on the SELECT (from a VALUES list) makes it a no-op when the table
// already has items, unless --force drops the guard.
const guard = force ? '' : '\nWHERE (SELECT count(*) FROM roadmap_item) = 0'
const sql = `INSERT INTO roadmap_item (id, title, description, status, position)
SELECT * FROM (VALUES
  ${values}
) AS v(id, title, description, status, position)${guard};`

const out = execSync('docker compose exec -T db psql -U nostragoalus -d nostragoalus -v ON_ERROR_STOP=1', {
  input: sql,
  encoding: 'utf8',
  shell: '/bin/sh',
})
const inserted = Number(/INSERT \d+ (\d+)/.exec(out)?.[1] ?? 0)
console.log(inserted > 0 ? `seeded ${inserted} roadmap item(s)` : 'roadmap already has items - skipped (pass --force to seed anyway)')
