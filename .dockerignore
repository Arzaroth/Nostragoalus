# Whitelist .dockerignore: ignore everything, then re-include only the build and
# runtime inputs. Deliberately a whitelist (the leading `*`) so new top-level
# junk - .claude worktrees, .pnpm-store, backups, caches - can never bloat the
# build context again. The Dockerfile does `COPY . .`, so anything not
# re-included below is invisible to the build (and to the dev/install layers).
*

# The web app package: source, framework config, drizzle migrations, the
# postbuild fingerprint script + its lib/integrity dep, and the app package.json.
!apps/web-nuxt
# ...but not its heavy build/dep artifacts (re-excluded so they never bloat the
# context or bust the COPY layer).
apps/web-nuxt/node_modules
apps/web-nuxt/.nuxt
apps/web-nuxt/.output
apps/web-nuxt/.data

# Cross-app shared DATA: locale JSON is read at build via the app's
# i18n/locales symlink into here; keep it in context so the symlink resolves.
!shared/i18n-json

# Root workspace manifests + npm/registry config.
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!.npmrc

# Imported at build time via ?raw (license.vue / about.vue / useChangelog).
!LICENSE
!LICENSE-MIT
!LICENSE-WTFPL
!CHANGELOG.md
!i18n/changelogs

# Colocated component tests (*.nuxt.test.ts) are not build inputs - re-exclude
# them after pulling in the app so they don't bust the COPY layer.
**/*.test.ts
