# Whitelist .dockerignore: ignore everything, then re-include only the build and
# runtime inputs. Deliberately a whitelist (the leading `*`) so new top-level
# junk - .claude worktrees, .pnpm-store, backups, caches - can never bloat the
# build context again. The Dockerfile does `COPY . .`, so anything not
# re-included below is invisible to the build (and to the dev/install layers).
*

# Source + framework config that `pnpm build` (nuxt) needs.
!app
!server
!shared
!lib
!db
!i18n
!public
!nuxt.config.ts
!tsconfig.json
!uno.config.ts
!.nuxtrc

# Committed migrations: the prod stage copies these from the build stage.
!drizzle

# Dependency manifests (pnpm fetch/install) + store/registry config.
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!.npmrc

# Imported at build time via ?raw by license.vue / about.vue - keep these.
!LICENSE
!LICENSE-MIT
!LICENSE-WTFPL
!CHANGELOG.md

# Colocated component tests (*.nuxt.test.ts) are not build inputs - re-exclude
# them after pulling in app/server so they don't bust the COPY layer.
**/*.test.ts
